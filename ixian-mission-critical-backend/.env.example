# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME="Mission Critical Backend"
VERSION="1.0.0"
DESCRIPTION="Mission Critical is a very handsome TODO app for homelabbers. It is built with FastAPI and PostgreSQL, and features ntfy notifications for task updates. It is part of the Ixian Protocol suite of apps, which aims to provide tools for homelabbers and tech enthusiasts."

# Environment
ENVIRONMENT="development"
DEBUG="True"

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# ntfy Notifications (optional - leave blank to disable)
NTFY_URL=http://ntfy:80
# NTFY_TOKEN=  # Optional: for authenticated ntfy servers
NTFY_TOPIC=ixian-mission-critical
